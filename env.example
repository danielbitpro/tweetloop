# ============================================================
# TweetLoop Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# The .env file is gitignored and should never be committed.
# ============================================================

# --------------------------------------------------
# Dashboard Access
# --------------------------------------------------
# Password required to access the dashboard.
# Change this to a strong password before running in production.
PASSWORD=change_me

# --------------------------------------------------
# Server
# --------------------------------------------------
# Port the app listens on (default: 7777)
PORT=7777

# Enable HTTPS (set to 'true' if you have SSL certs in certs/)
# Place cert.pem and key.pem in the certs/ directory.
HTTPS_ENABLED=false

# --------------------------------------------------
# Twitter / X Integration (Optional)
# --------------------------------------------------
# Required for the "Post to X" button in the dashboard.
#
# Setup:
#   1. Run: xurl auth oauth2 --app twitter
#   2. Follow the browser flow to authorize
#   3. Copy the OAuth1 tokens below
#
# If left empty, the "Post to X" button will show an error.
# The app still works fully for reviewing/editing tweets without this.
XURL_APP_OAUTH1_TOKEN=
XURL_APP_OAUTH1_TOKEN_SECRET=
XURL_APP_OAUTH1_SECRET=

# --------------------------------------------------
# Pipeline Bridge (Optional)
# --------------------------------------------------
# Paths for the pipeline bridge script.
# Only needed if you run the bridge externally.
#
# TLP_WORKSPACE=/path/to/workspace        # Directory containing *-final.md files
# TLP_DB_PATH=/path/to/data/tweetloop.db  # Path to the SQLite database

# --------------------------------------------------
# Supabase Mode (Optional)
# --------------------------------------------------
# Uncomment and fill to use Supabase PostgreSQL instead of SQLite.
# This enables multi-user auth, analytics, and cloud features.
#
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=your-service-key
